<view class="page-shell">
  <view class="hero-panel">
    <view class="hero-title">库存与利用情况</view>
    <view class="hero-desc">查询设备、仪器和试剂的库存与当前利用状态。</view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">类型筛选</text>
      <text class="section-note">先选类型再查库存</text>
    </view>
    <view class="card form-card">
      <view class="toolbar inventory-toolbar">
        <view
          wx:for="{{filters}}"
          wx:key="*this"
          class="chip {{activeFilter === item ? 'chip-active' : ''}}"
          data-value="{{item}}"
          bindtap="switchFilter"
        >
          {{item}}
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">搜索库存</text>
      <text class="section-note">{{visibleItems.length}} 项结果</text>
    </view>
    <view class="card form-card">
      <view class="search-row">
        <input
          class="field-control search-input"
          placeholder="搜索名称、规格、位置、危险类型、利用状态"
          value="{{keywordInput}}"
          bindinput="onKeywordInput"
          bindconfirm="onSearchSubmit"
          confirm-type="search"
        />
        <view class="search-btn" bindtap="onSearchSubmit">搜索</view>
      </view>
      <view class="search-record-link" bindtap="openRecordsPage">查看使用记录与出入库记录</view>
    </view>
  </view>

  <view class="section">
    <view class="record-list" wx:if="{{visibleItems.length}}">
      <view class="card" wx:for="{{visibleItems}}" wx:key="id">
        <view class="record-title">{{item.name}}</view>
        <view class="badge-row">
          <text class="badge badge-primary">{{item.category}}</text>
          <text class="badge {{item.statusTone}}">{{item.statusText}}</text>
          <text class="badge badge-primary">库存 {{item.stock}}{{item.unit}}</text>
          <text wx:if="{{item.isHazardous}}" class="badge badge-danger">{{item.hazardType}}</text>
        </view>
        <view class="detail-grid">
          <view class="detail-item">
            <view class="detail-label">规格</view>
            <view class="detail-value">{{item.spec || '无规格'}}</view>
          </view>
          <view class="detail-item">
            <view class="detail-label">位置</view>
            <view class="detail-value">{{item.location || '未配置库位'}}</view>
          </view>
          <view class="detail-item">
            <view class="detail-label">状态</view>
            <view class="detail-value">{{item.statusDetail}}</view>
          </view>
          <view class="detail-item">
            <view class="detail-label">安全库存</view>
            <view class="detail-value">{{item.minStock}}{{item.unit}}</view>
          </view>
        </view>
      </view>
    </view>
    <view class="card empty-state" wx:else>没有找到匹配的库存或利用情况</view>
  </view>
</view>
