<view class="page-shell">
  <view class="hero-panel">
    <view class="hero-kicker">STOCK FLOW</view>
    <view class="hero-title">出入库与库存台账</view>
    <view class="hero-desc">针对大型设备、仪器和试剂统一管理库存变化。每次登记都会即时回写库存数量，并保留操作记录。</view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">物资分类</text>
      <text class="section-note">点击筛选库存</text>
    </view>
    <view class="toolbar">
      <view
        wx:for="{{filters}}"
        wx:key="*this"
        class="chip {{activeFilter === item ? 'chip-active' : ''}}"
        data-value="{{item}}"
        bindtap="switchFilter"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">出入库登记</text>
      <text class="section-note">本地演示数据可直接新增</text>
    </view>
    <view class="card form-card">
      <view class="form-grid">
        <view>
          <view class="field-label">选择物资</view>
          <picker range="{{stockOptions}}" range-key="name" value="{{form.itemIndex}}" data-field="itemIndex" bindchange="onPickerChange">
            <view class="field-control">{{stockOptions.length ? stockOptions[form.itemIndex].name : '暂无物资'}}</view>
          </picker>
        </view>
        <view>
          <view class="field-label">操作类型</view>
          <picker range="{{movementTypes}}" value="{{form.typeIndex}}" data-field="typeIndex" bindchange="onPickerChange">
            <view class="field-control">{{movementTypes[form.typeIndex]}}</view>
          </picker>
        </view>
        <view>
          <view class="field-label">数量</view>
          <input class="field-control" type="digit" placeholder="请输入数量" value="{{form.quantity}}" data-field="quantity" bindinput="onInput" />
        </view>
        <view>
          <view class="field-label">操作人</view>
          <input class="field-control" placeholder="例如：仓管员 / 实验员" value="{{form.operator}}" data-field="operator" bindinput="onInput" />
        </view>
        <view>
          <view class="field-label">备注</view>
          <textarea class="field-control textarea-control" placeholder="填写入库批次、领用用途等说明" value="{{form.remark}}" data-field="remark" bindinput="onInput"></textarea>
        </view>
        <button class="submit-btn" bindtap="submitForm">提交登记</button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">当前库存</text>
      <text class="section-note">{{items.length}} 项</text>
    </view>
    <view class="record-list" wx:if="{{items.length}}">
      <view class="card" wx:for="{{items}}" wx:key="id">
        <view class="record-title">{{item.name}}</view>
        <view class="badge-row">
          <text class="badge badge-primary">{{item.category}}</text>
          <text class="badge {{item.stock <= item.minStock ? 'badge-warning' : 'badge-primary'}}">库存 {{item.stock}}{{item.unit}}</text>
          <text wx:if="{{item.isHazardous}}" class="badge badge-danger">{{item.hazardType}}</text>
        </view>
        <view class="record-meta">规格：{{item.spec}}</view>
        <view class="record-meta">库位：{{item.location}}</view>
        <view class="record-meta">安全库存：{{item.minStock}}{{item.unit}}</view>
      </view>
    </view>
    <view class="card empty-state" wx:else>当前筛选下暂无物资</view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">出入库记录</text>
      <text class="section-note">按时间倒序</text>
    </view>
    <view class="record-list">
      <view class="card" wx:for="{{movements}}" wx:key="id">
        <view class="record-title">{{item.itemName}}</view>
        <view class="badge-row">
          <text class="badge {{item.type === '出库' ? 'badge-warning' : 'badge-primary'}}">{{item.type}}</text>
          <text class="badge badge-primary">{{item.quantity}}{{item.unit}}</text>
        </view>
        <view class="record-meta">操作人：{{item.operator}}</view>
        <view class="record-meta">时间：{{item.date}}</view>
        <view class="record-meta">说明：{{item.remark || '无'}}</view>
      </view>
    </view>
  </view>
</view>
