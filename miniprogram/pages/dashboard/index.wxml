<view class="page-shell">
  <view class="hero-panel">
    <view class="hero-kicker">LAB STOCK CONTROL</view>
    <view class="hero-title">实验室出入库指挥台</view>
    <view class="hero-desc">集中查看库存状态、危险试剂、大型设备占用情况和最新使用动态，适合仓管与实验平台主管快速巡检。</view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">关键指标</text>
      <text class="section-note">进入页面自动刷新</text>
    </view>
    <view class="grid-two" wx:if="{{metrics}}">
      <view class="card metric-card">
        <text class="metric-label">库存物资</text>
        <text class="metric-value">{{metrics.totalSku}}</text>
        <text class="metric-foot">覆盖设备、仪器、试剂</text>
      </view>
      <view class="card metric-card">
        <text class="metric-label">危险试剂</text>
        <text class="metric-value">{{metrics.hazardousCount}}</text>
        <text class="metric-foot">重点关注领用流向</text>
      </view>
      <view class="card metric-card">
        <text class="metric-label">低库存预警</text>
        <text class="metric-value">{{metrics.lowStockCount}}</text>
        <text class="metric-foot">建议优先补货</text>
      </view>
      <view class="card metric-card">
        <text class="metric-label">设备占用</text>
        <text class="metric-value">{{metrics.activeEquipmentCount}}</text>
        <text class="metric-foot">当前使用中的大型设备</text>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{metrics}}">
    <view class="section-head">
      <text class="section-title">最新出入库</text>
      <text class="section-note">近 4 条</text>
    </view>
    <view class="record-list">
      <view class="card" wx:for="{{metrics.recentMovements}}" wx:key="id">
        <view class="record-title">{{item.itemName}}</view>
        <view class="badge-row">
          <text class="badge {{item.type === '出库' ? 'badge-warning' : 'badge-primary'}}">{{item.type}}</text>
          <text class="badge badge-primary">{{item.quantity}}{{item.unit}}</text>
        </view>
        <view class="record-meta">操作人：{{item.operator}}</view>
        <view class="record-meta">时间：{{item.date}}</view>
        <view class="record-meta">备注：{{item.remark || '无'}}</view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{metrics}}">
    <view class="section-head">
      <text class="section-title">大型设备使用动态</text>
      <text class="section-note">近 3 条</text>
    </view>
    <view class="record-list">
      <view class="card" wx:for="{{metrics.equipmentUsageRecords}}" wx:key="id">
        <view class="record-title">{{item.deviceName}}</view>
        <view class="badge-row">
          <text class="badge {{item.status === '使用中' ? 'badge-danger' : 'badge-primary'}}">{{item.status}}</text>
          <text class="badge badge-primary">{{item.user}}</text>
        </view>
        <view class="record-meta">用途：{{item.purpose}}</view>
        <view class="record-meta">时段：{{item.startTime}} - {{item.endTime}}</view>
        <view class="record-meta">备注：{{item.remark || '无'}}</view>
      </view>
    </view>
  </view>
</view>
