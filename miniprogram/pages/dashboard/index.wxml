<view class="page-shell">
  <view class="hero-panel">
    <view class="hero-title">实验室出入库指挥台</view>
    <view class="hero-desc">查看总览指标并快速进入库存、登记和记录查询。</view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">关键指标</text>
      <text class="section-note">进入页面自动刷新</text>
    </view>
    <view class="grid-two" wx:if="{{metrics}}">
      <view class="card metric-card">
        <text class="metric-label">库存物资</text>
        <text class="metric-value">{{metrics.totalSku}}</text>
        <text class="metric-foot">覆盖设备、仪器、试剂</text>
      </view>
      <view class="card metric-card">
        <text class="metric-label">危险试剂</text>
        <text class="metric-value">{{metrics.hazardousCount}}</text>
        <text class="metric-foot">重点关注领用流向</text>
      </view>
      <view class="card metric-card">
        <text class="metric-label">低库存预警</text>
        <text class="metric-value">{{metrics.lowStockCount}}</text>
        <text class="metric-foot">建议优先补货</text>
      </view>
      <view class="card metric-card">
        <text class="metric-label">设备占用</text>
        <text class="metric-value">{{metrics.activeEquipmentCount}}</text>
        <text class="metric-foot">当前使用中的大型设备</text>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{metrics}}">
    <view class="section-head">
      <text class="section-title">快捷入口</text>
      <text class="section-note">围绕库存与登记</text>
    </view>
    <view class="grid-two">
      <view class="card quick-card" bindtap="openInventory">
        <text class="record-title">库存总览</text>
        <text class="record-meta">搜索大型设备、仪器、试剂的库存和利用情况</text>
      </view>
      <view class="card quick-card" bindtap="openOperations">
        <text class="record-title">登记中心</text>
        <text class="record-meta">统一处理借用、使用、出入库登记</text>
      </view>
      <view class="card quick-card" bindtap="openRecords">
        <text class="record-title">记录查询</text>
        <text class="record-meta">集中检索出入库和使用台账</text>
      </view>
      <view class="card quick-card" bindtap="openOperations">
        <text class="record-title">快速操作</text>
        <text class="record-meta">直接进入登记页面完成当前实验室动作</text>
      </view>
    </view>
  </view>
</view>
