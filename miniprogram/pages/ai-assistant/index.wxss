.ai-page {
  padding-bottom: 240rpx;
}

.ai-hero {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at top right, rgba(193, 219, 255, 0.5), transparent 34%),
    linear-gradient(180deg, rgba(247, 250, 255, 0.82) 0%, rgba(241, 247, 255, 0.74) 100%);
}

.ai-hero::after {
  content: '';
  position: absolute;
  right: -72rpx;
  top: 26rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 44rpx;
  border: 2rpx solid rgba(132, 169, 216, 0.18);
  transform: rotate(18deg);
}

.message-row {
  display: flex;
}

.message-row-user {
  justify-content: flex-end;
}

.message-row-assistant {
  justify-content: flex-start;
}

.message-card {
  width: 88%;
  border-radius: 28rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(99, 138, 186, 0.1);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.message-card-assistant {
  background: rgba(249, 252, 255, 0.84);
  border: 2rpx solid rgba(132, 169, 216, 0.18);
}

.message-card-user {
  background: rgba(181, 213, 251, 0.28);
  border: 2rpx solid rgba(98, 148, 210, 0.18);
  color: #214d7e;
}

.message-role {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  opacity: 0.72;
}

.message-text {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.75;
}

.query-card,
.action-card,
.archive-card {
  background: rgba(248, 252, 255, 0.8);
}

.message-inline-card {
  width: 88%;
}

.query-item-list,
.draft-board,
.archive-lines,
.stocktake-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.query-item-list {
  max-height: 420rpx;
  overflow-y: auto;
  padding-right: 6rpx;
  -webkit-overflow-scrolling: touch;
}

.query-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.query-search-btn {
  width: 112rpx;
  min-width: 112rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin-top: 0;
  padding: 0;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #2c649c;
  background: rgba(120, 173, 237, 0.2);
  border: 2rpx solid rgba(98, 148, 210, 0.2);
  box-shadow: 0 10rpx 24rpx rgba(111, 157, 214, 0.1);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.query-search-btn::after {
  border: 0;
}

.query-item,
.stocktake-item {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(194, 221, 255, 0.16);
  border: 2rpx solid rgba(132, 169, 216, 0.14);
}

.query-item-title,
.stocktake-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #193753;
}

.archive-line {
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(194, 221, 255, 0.16);
  color: #3b648f;
  font-size: 24rpx;
}

.draft-card {
  background: linear-gradient(180deg, rgba(250, 252, 255, 0.92) 0%, rgba(244, 249, 255, 0.82) 100%);
}

.draft-card-pending {
  border-color: rgba(93, 145, 209, 0.24);
  box-shadow: 0 16rpx 28rpx rgba(108, 153, 210, 0.1);
}

.draft-line {
  font-size: 32rpx;
  font-weight: 700;
  color: #18344f;
}

.draft-note {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #5f85ad;
  line-height: 1.7;
}

.candidate-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.candidate-title {
  font-size: 24rpx;
  color: #5e7fa4;
}

.candidate-card {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(193, 220, 255, 0.16);
  border: 2rpx solid rgba(132, 169, 216, 0.16);
}

.candidate-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #193753;
}

.candidate-meta,
.candidate-reason {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6f8cac;
}

.create-card {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(237, 245, 255, 0.74);
  border: 2rpx solid rgba(132, 169, 216, 0.16);
}

.create-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.compact-control {
  min-height: 76rpx;
  padding: 16rpx 20rpx;
}

.hazard-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.hint-card {
  background: rgba(242, 248, 255, 0.82);
  border-color: rgba(132, 169, 216, 0.18);
}

.action-card {
  background: linear-gradient(180deg, rgba(244, 249, 255, 0.86) 0%, rgba(236, 245, 255, 0.8) 100%);
  color: #17324b;
  border-color: rgba(132, 169, 216, 0.18);
}

.action-card .record-title,
.action-card .record-meta,
.action-card .field-label {
  color: #17324b;
}

.confirm-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #6487ae;
  opacity: 0.9;
}

.completion-note {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(198, 223, 255, 0.22);
  font-size: 24rpx;
  line-height: 1.6;
}

.confirm-btn,
.create-btn {
  margin-top: 18rpx;
  background: rgba(120, 173, 237, 0.2);
  border: 2rpx solid rgba(98, 148, 210, 0.22);
  color: #2c649c;
}

.composer-section {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 16rpx);
  z-index: 30;
  margin-top: 0;
}

.composer-card {
  background: rgba(248, 252, 255, 0.84);
  padding: 10rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(132, 169, 216, 0.18);
  box-shadow: 0 16rpx 34rpx rgba(99, 138, 186, 0.12);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
}

.composer-row {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
}

.composer-input {
  min-height: 74rpx;
}

.composer-input-inline {
  flex: 1;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  line-height: 1.5;
  max-height: 118rpx;
  background: rgba(255, 255, 255, 0.8);
}

.composer-send-btn {
  width: 84rpx;
  min-width: 84rpx;
  height: 74rpx;
  margin-top: 0;
  padding: 0;
  border-radius: 18rpx;
  font-size: 20rpx;
  font-weight: 700;
  background: rgba(120, 173, 237, 0.2);
  color: #2c649c;
  border: 2rpx solid rgba(98, 148, 210, 0.22);
  line-height: 74rpx;
  flex: 0 0 84rpx;
  box-shadow: 0 10rpx 24rpx rgba(111, 157, 214, 0.1);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.composer-send-btn::after {
  border: 0;
}
