<view class="page-shell ai-page">
  <view class="hero-panel ai-hero">
    <view class="hero-kicker">AI INVENTORY COPILOT</view>
    <view class="hero-title">AI 库存助手</view>
    <view class="hero-desc">查询、出入库、盘点和预警调整都可以直接交给我；当需要你确认时，我会把操作卡片直接展示在对话里。</view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">对话记录</text>
      <text class="section-note">长按消息可复制</text>
    </view>
    <view class="record-list">
      <block wx:for="{{messages}}" wx:key="id" wx:for-item="message">
        <view
          wx:if="{{message.kind === 'text'}}"
          class="message-row {{message.role === 'user' ? 'message-row-user' : 'message-row-assistant'}}"
        >
          <view
            class="message-card {{message.role === 'user' ? 'message-card-user' : 'message-card-assistant'}}"
            data-text="{{message.text}}"
            bindlongpress="copyMessage"
          >
            <view class="message-role">{{message.role === 'user' ? '你' : 'AI'}}</view>
            <view class="message-text">{{message.text}}</view>
          </view>
        </view>

        <view wx:if="{{message.kind === 'result_card'}}" class="message-row message-row-assistant">
          <view class="card message-inline-card query-card">
            <view class="query-card-head">
              <view class="record-title">{{message.card.title}}</view>
              <button class="query-search-btn" bindtap="openInventorySearch">搜索</button>
            </view>
            <view class="record-meta" wx:if="{{message.card.summary}}">{{message.card.summary}}</view>
            <view class="query-item-list">
              <view class="query-item" wx:for="{{message.card.items}}" wx:key="itemId">
                <view class="query-item-title">{{item.name}}</view>
                <view class="badge-row">
                  <text class="badge badge-primary">库存 {{item.stock}}{{item.unit}}</text>
                  <text class="badge badge-warning" wx:if="{{item.beforeStock !== null && item.beforeStock !== undefined}}">操作前 {{item.beforeStock}}{{item.unit}}</text>
                  <text class="badge badge-warning" wx:if="{{item.beforeMinStock !== null && item.beforeMinStock !== undefined}}">原预警 {{item.beforeMinStock}}{{item.unit}}</text>
                  <text class="badge badge-primary" wx:if="{{item.minStock !== null && item.minStock !== undefined}}">预警 {{item.minStock}}{{item.unit}}</text>
                  <text class="badge badge-primary" wx:if="{{item.spec}}">{{item.spec}}</text>
                </view>
                <view class="record-meta" wx:if="{{item.location}}">位置 {{item.location}}</view>
              </view>
              <view class="record-meta" wx:if="{{!message.card.items || !message.card.items.length}}">暂无可展示的库存明细</view>
            </view>
          </view>
        </view>

        <view wx:if="{{message.kind === 'pending_action'}}" class="message-row message-row-assistant">
          <view class="card message-inline-card action-card">
            <view class="confirm-kicker">ACTION CARD</view>
            <view class="record-title">{{message.title}}</view>
            <view class="record-meta" wx:if="{{message.summary}}">{{message.summary}}</view>

            <view class="stocktake-list" wx:if="{{message.actionType === 'movement_confirm'}}">
              <view class="stocktake-item" wx:for="{{message.items}}" wx:key="itemId">
                <view class="stocktake-title">{{item.itemName}}</view>
                <view class="badge-row">
                  <text class="badge {{item.type === '出库' ? 'badge-warning' : 'badge-primary'}}">{{item.type || '待确认'}}</text>
                  <text class="badge badge-primary">{{item.quantity}}{{item.unit}}</text>
                  <text class="badge badge-primary">库存 {{item.currentQuantity}}{{item.unit}}</text>
                </view>
                <view class="record-meta" wx:if="{{item.remark}}">{{item.remark}}</view>
              </view>
            </view>

            <view class="stocktake-list" wx:if="{{message.actionType === 'stocktake_confirm'}}">
              <view class="stocktake-item" wx:for="{{message.items}}" wx:key="itemId">
                <view class="stocktake-title">{{item.itemName}}</view>
                <view class="badge-row">
                  <text class="badge badge-primary">系统 {{item.currentQuantity}}{{item.unit}}</text>
                  <text class="badge badge-warning">实盘 {{item.countedQuantity}}{{item.unit}}</text>
                  <text class="badge {{item.difference >= 0 ? 'badge-primary' : 'badge-danger'}}">差异 {{item.difference >= 0 ? '+' : ''}}{{item.difference}}{{item.unit}}</text>
                </view>
                <view class="record-meta" wx:if="{{item.remark}}">{{item.remark}}</view>
              </view>
            </view>

            <view class="stocktake-list" wx:if="{{message.actionType === 'threshold_confirm'}}">
              <view class="stocktake-item" wx:for="{{message.items}}" wx:key="itemId">
                <view class="stocktake-title">{{item.itemName}}</view>
                <view class="badge-row">
                  <text class="badge badge-warning">当前预警 {{item.currentMinStock}}{{item.unit}}</text>
                  <text class="badge badge-primary">调整为 {{item.minStock}}{{item.unit}}</text>
                </view>
                <view class="record-meta" wx:if="{{item.remark}}">{{item.remark}}</view>
              </view>
            </view>

            <view wx:if="{{pendingAction && pendingAction.messageId === message.id}}">
              <view class="field-label" wx:if="{{message.requiresOperator}}">操作人</view>
              <input
                wx:if="{{message.requiresOperator}}"
                class="field-control"
                placeholder="请输入本次确认人"
                value="{{operatorName}}"
                bindinput="onOperatorInput"
              />
              <button class="submit-btn confirm-btn" loading="{{confirming}}" bindtap="confirmAction">{{message.buttonText || '确认执行'}}</button>
            </view>

            <view wx:if="{{message.completed}}" class="completion-note">{{message.completionNote}}</view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="section" wx:if="{{hasDraftLines}}">
    <view class="section-head">
      <text class="section-title">待执行内容</text>
      <text class="section-note">{{draftLines.length}} 条</text>
    </view>
    <view class="draft-board">
      <view
        wx:for="{{draftLines}}"
        wx:key="draftId"
        wx:for-item="line"
        wx:for-index="lineIndex"
        class="card draft-card {{line.status !== 'confirmed' ? 'draft-card-pending' : ''}}"
      >
        <view class="draft-line">{{line.text}}</view>
        <view class="badge-row">
          <text class="badge {{line.type === '出库' ? 'badge-warning' : 'badge-primary'}}">{{line.type || '待补全'}}</text>
          <text class="badge badge-primary">{{line.itemName || '待确认物资'}}</text>
          <text class="badge badge-primary">{{line.quantity}}{{line.unit}}</text>
        </view>
        <view class="draft-note" wx:if="{{line.selectionHint}}">{{line.selectionHint}}</view>

        <view class="candidate-list" wx:if="{{line.status === 'needs_selection'}}">
          <view class="candidate-title">请选择准确物品</view>
          <view
            wx:for="{{line.candidates}}"
            wx:key="itemId"
            wx:for-item="option"
            wx:for-index="optionIndex"
            class="candidate-card"
            data-line-index="{{lineIndex}}"
            data-option-index="{{optionIndex}}"
            bindtap="selectCandidate"
          >
            <view class="candidate-name">{{option.name}}</view>
            <view class="candidate-meta">{{option.category}} · {{option.spec || '无规格'}} · {{option.unit || '无单位'}}</view>
            <view class="candidate-meta">位置：{{option.location || '未配置'}}</view>
            <view class="candidate-reason" wx:if="{{option.reason}}">{{option.reason}}</view>
          </view>
        </view>

        <view class="create-card" wx:if="{{line.status === 'needs_create'}}">
          <view class="candidate-title">目录中没有对应物资，可以直接新建</view>
          <view class="create-grid">
            <view>
              <view class="field-label">物资名称</view>
              <input class="field-control compact-control" value="{{line.createForm.name}}" data-line-index="{{lineIndex}}" data-field="name" bindinput="onCreateFieldInput" />
            </view>
            <view>
              <view class="field-label">分类</view>
              <input class="field-control compact-control" value="{{line.createForm.category}}" data-line-index="{{lineIndex}}" data-field="category" bindinput="onCreateFieldInput" />
            </view>
            <view>
              <view class="field-label">规格</view>
              <input class="field-control compact-control" value="{{line.createForm.spec}}" data-line-index="{{lineIndex}}" data-field="spec" bindinput="onCreateFieldInput" />
            </view>
            <view>
              <view class="field-label">单位</view>
              <input class="field-control compact-control" value="{{line.createForm.unit}}" data-line-index="{{lineIndex}}" data-field="unit" bindinput="onCreateFieldInput" />
            </view>
            <view>
              <view class="field-label">库位</view>
              <input class="field-control compact-control" value="{{line.createForm.location}}" data-line-index="{{lineIndex}}" data-field="location" bindinput="onCreateFieldInput" />
            </view>
            <view>
              <view class="field-label">当前库存</view>
              <input class="field-control compact-control" type="digit" value="{{line.createForm.stock}}" data-line-index="{{lineIndex}}" data-field="stock" bindinput="onCreateFieldInput" />
            </view>
            <view>
              <view class="field-label">安全库存</view>
              <input class="field-control compact-control" type="digit" value="{{line.createForm.minStock}}" data-line-index="{{lineIndex}}" data-field="minStock" bindinput="onCreateFieldInput" />
            </view>
            <view class="hazard-switch-row">
              <view class="field-label">危险品</view>
              <switch checked="{{line.createForm.isHazardous}}" color="#C65D2E" data-line-index="{{lineIndex}}" bindchange="onCreateSwitchChange" />
            </view>
            <view wx:if="{{line.createForm.isHazardous}}">
              <view class="field-label">危险类型</view>
              <input class="field-control compact-control" value="{{line.createForm.hazardType}}" data-line-index="{{lineIndex}}" data-field="hazardType" bindinput="onCreateFieldInput" />
            </view>
          </view>
          <button class="submit-btn create-btn" data-line-index="{{lineIndex}}" bindtap="createItemFromDraft">新建物资并继续</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{pendingCount > 0}}">
    <view class="card hint-card">
      <view class="record-title">还有 {{pendingCount}} 条待处理内容</view>
      <view class="record-meta">你可以继续补充一句话，也可以直接在卡片上选择物资或新建物资。</view>
    </view>
  </view>

  <view class="section composer-section">
    <view class="card composer-card">
      <view class="composer-row">
        <textarea
          class="field-control composer-input composer-input-inline"
          value="{{inputText}}"
          auto-height="true"
          maxlength="500"
          bindinput="onInputChange"
        ></textarea>
        <button class="composer-send-btn" loading="{{sending}}" bindtap="submitMessage">发送</button>
      </view>
    </view>
  </view>
</view>
